<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.polimi.ingsw.galaxytrucker.TileCardsJsonUtility">

    <Label text="Gestione Pedine" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <ImageView fx:id="imageView" fitWidth="200" fitHeight="200"/>

    <Button text="Carica Immagine" onAction="#handleLoadFronte"/>

    <HBox spacing="10">
        <Label text="Nome Pedina:"/>
        <TextField fx:id="textFieldNome" promptText="Inserisci il nome..."/>
    </HBox>

    <HBox spacing="10">
        <Label text="Tipo Pedina:"/>
        <ComboBox fx:id="comboBoxTipo">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Guerriero"/>
                    <String fx:value="Mago"/>
                    <String fx:value="Arciere"/>
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <Button text="Salva Pedina" onAction="#handleSavePedina"/>

</VBox>