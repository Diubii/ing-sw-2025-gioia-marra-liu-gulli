<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="10" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.polimi.ingsw.galaxytrucker.TileCardsJsonUtility">
    <HBox spacing="20">
        <Label text="TILES" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <Button text="Salva la lista" onAction="#handleAddToList"/>
        <Button text="Carica la lista" onAction="#handleAddToList"/>
    </HBox>
    <HBox spacing="20">
        <VBox>
            <HBox spacing="10">
                <ImageView fx:id="tileImageView" fitWidth="181" fitHeight="181"/>
            </HBox>
            <VBox spacing="10">
                <Button text="Carica Immagine" onAction="#handleLoadTileImage"/>
                <Label text="ID (da 1 a 157 come immagini):"/>
                <TextField fx:id="tileId"/>

                <HBox spacing="10">
                    <Label text="Tipo Component:"/>
                    <ComboBox fx:id="tileComponentType">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Cannone"/>
                                <String fx:value="Batterie"/>
                                <String fx:value="Cabina"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Label text="ValExtra (nBatterie,nSlot...:"/>
                    <TextField fx:id="extraVal"/>
                </HBox>
            </VBox>
        </VBox>
        <VBox spacing="10">
            <HBox spacing="10">
                <Label text="Top Connettore:"/>
                <ComboBox fx:id="comboBoxTopConn" value="Empty">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Empty"/>
                            <String fx:value="Single"/>
                            <String fx:value="Double"/>
                            <String fx:value="Universal"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>
            <HBox spacing="10">
                <Label text="RConnettore:"/>
                <ComboBox fx:id="comboBoxRConn" value="Empty">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Empty"/>
                            <String fx:value="Single"/>
                            <String fx:value="Double"/>
                            <String fx:value="Universal"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>
            <HBox spacing="10">
                <Label text="Bottom Connettore:"/>
                <ComboBox fx:id="comboBoxBotConn" value="Empty">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Empty"/>
                            <String fx:value="Single"/>
                            <String fx:value="Double"/>
                            <String fx:value="Universal"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>
            <HBox spacing="10">
                <Label text="LConnettore:"/>
                <ComboBox fx:id="comboBoxLConn" value="Empty">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Empty"/>
                            <String fx:value="Single"/>
                            <String fx:value="Double"/>
                            <String fx:value="Universal"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>


        </VBox>
    </HBox>

    <Button text="Aggiungi a lista" onAction="#handleAddToList"/>

</VBox>