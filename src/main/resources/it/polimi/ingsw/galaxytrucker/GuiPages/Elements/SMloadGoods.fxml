<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.polimi.ingsw.galaxytrucker.view.Gui.Elements.SMloadGoodsController">
   <Button mnemonicParsing="false" onAction="#fineLoad" styleClass="button-confirm" stylesheets="@../style.css" text="Termina (scarta le merci sottostanti)" />
   
   <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="258.0" stylesheets="@../style.css">
      <content>
         <FlowPane fx:id="listaGoods" onMouseClicked="#dropGood" prefHeight="100.0" prefWidth="250.0" styleClass="OverlayPanel" stylesheets="@../style.css" />
      </content>
   </ScrollPane>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
