<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.polimi.ingsw.galaxytrucker.view.Gui.Elements.SMactivateCardController">
   <Button mnemonicParsing="false" onAction="#activate" styleClass="button-confirm" stylesheets="@../style.css" text="Attiva carta">
      <font>
         <Font name="System Bold" size="18.0" />
      </font></Button>
   <Button layoutX="20.0" layoutY="20.0" mnemonicParsing="false" onAction="#pass" styleClass="button-cancel" stylesheets="@../style.css" text="Passala">
      <font>
         <Font name="System Bold" size="18.0" />
      </font></Button>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
